# Production environment for DocShare — copy to /opt/docshare/.env on the VPS.
# systemd loads this via EnvironmentFile, and config/runtime.exs also reads it.
# NOTE: no `export`, no surrounding quotes. Each value is the rest of the line.

# Required: tells the release to actually start the web server.
PHX_SERVER=true

# Public hostname (used for URLs and email links). No scheme.
PHX_HOST=docshare.gatetroy.com

# Port the app listens on locally (put nginx/Caddy in front for TLS on 443).
PORT=4000

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=REPLACE_WITH_64_BYTE_SECRET

# Local Postgres on the VPS.
DATABASE_URL=ecto://docshare:REPLACE_DB_PASSWORD@localhost/docshare_prod
POOL_SIZE=10

# Resend (gatetroy.com must be verified in Resend before using this sender).
RESEND_API_KEY=re_REPLACE_ME
MAIL_FROM=DocShare <noreply@gatetroy.com>
