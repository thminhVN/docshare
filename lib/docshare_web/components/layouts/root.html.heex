<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="description"
      content="DocShare is a collaborative HTML document review app for sharing HTML by email, collecting anchored comments, comparing versions, and exporting feedback for AI-assisted edits."
    />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="application-name" content="DocShare" />
    <meta name="theme-color" content="#4f46e5" />
    <meta name="author" content="DocShare" />
    <link rel="canonical" href="https://docshare.gatetroy.com/" />
    <link rel="icon" type="image/svg+xml" href={~p"/images/brand/favicon.svg"} />
    <link rel="icon" type="image/png" sizes="1024x1024" href={~p"/images/brand/favicon-1024.png"} />
    <link rel="apple-touch-icon" href={~p"/images/brand/favicon-1024.png"} />
    <meta property="og:site_name" content="DocShare" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://docshare.gatetroy.com/" />
    <meta property="og:title" content="DocShare — Collaborative HTML Review" />
    <meta
      property="og:description"
      content="Host an HTML document online, invite collaborators by email, comment on each section, compare versions, and export feedback for AI-assisted fixes."
    />
    <meta property="og:image" content="https://docshare.gatetroy.com/images/og-docshare.png" />
    <meta
      property="og:image:secure_url"
      content="https://docshare.gatetroy.com/images/og-docshare.png"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="DocShare collaborative HTML review interface" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="DocShare — Collaborative HTML Review" />
    <meta
      name="twitter:description"
      content="Share HTML documents, collect anchored comments, compare versions, and export feedback for AI-assisted edits."
    />
    <meta name="twitter:image" content="https://docshare.gatetroy.com/images/og-docshare.png" />
    <script type="application/ld+json">
      <%= Phoenix.HTML.raw(
        Jason.encode!(%{
          "@context" => "https://schema.org",
          "@type" => "SoftwareApplication",
          "name" => "DocShare",
          "applicationCategory" => "BusinessApplication",
          "operatingSystem" => "Web",
          "url" => "https://docshare.gatetroy.com/",
          "description" =>
            "A collaborative HTML document review app for sharing HTML by email, anchored comments, version comparison, and AI-assisted feedback export.",
          "offers" => %{
            "@type" => "Offer",
            "price" => "0",
            "priceCurrency" => "USD"
          },
          "creator" => %{
            "@type" => "Organization",
            "name" => "DocShare"
          }
        })
      ) %>
    </script>
    <.live_title default="DocShare" suffix=" · DocShare">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
  </head>
  <body class="bg-white">
    <header class="border-b border-zinc-100 bg-white">
      <div class="mx-auto w-full max-w-[1700px] flex items-center justify-between px-4 sm:px-6 lg:px-8 2xl:px-12 py-3">
        <.link href={~p"/"} class="inline-flex items-center">
          <img
            src={~p"/images/brand/logo-horizontal.svg"}
            alt="DocShare"
            class="h-8 w-auto"
            width="1800"
            height="440"
          />
        </.link>
        <%!-- Desktop nav --%>
        <nav class="hidden sm:flex items-center gap-4 text-[0.8125rem] leading-6">
          <%= if @current_user do %>
            <.link href={~p"/docs"} class="text-indigo-700 font-semibold hover:text-indigo-500">
              My documents
            </.link>
            <span class="text-zinc-500">{@current_user.email}</span>
            <.link
              href={~p"/users/settings"}
              class="text-zinc-900 font-semibold hover:text-zinc-700"
            >
              Settings
            </.link>
            <.link
              href={~p"/users/log_out"}
              method="delete"
              class="text-zinc-900 font-semibold hover:text-zinc-700"
            >
              Log out
            </.link>
          <% else %>
            <.link
              href={~p"/users/register"}
              class="text-zinc-900 font-semibold hover:text-zinc-700"
            >
              Register
            </.link>
            <.link
              href={~p"/users/log_in"}
              class="text-zinc-900 font-semibold hover:text-zinc-700"
            >
              Log in
            </.link>
          <% end %>
        </nav>

        <%!-- Mobile hamburger --%>
        <button
          type="button"
          data-menu-toggle
          aria-label="Open menu"
          aria-controls="mobile-menu"
          class="sm:hidden -mr-2 inline-flex items-center justify-center rounded-lg p-2 text-zinc-700 hover:bg-zinc-100 hover:text-zinc-900"
        >
          <svg
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
          </svg>
        </button>
      </div>
    </header>

    <%!-- Mobile slide-over menu --%>
    <div
      id="mobile-menu"
      class="hidden sm:hidden fixed inset-0 z-50"
      role="dialog"
      aria-modal="true"
    >
      <div
        data-menu-overlay
        data-menu-close
        class="absolute inset-0 bg-zinc-900/40 opacity-0 transition-opacity duration-200"
      >
      </div>
      <div
        data-menu-panel
        class="absolute inset-y-0 right-0 flex w-72 max-w-[80%] translate-x-full flex-col bg-white shadow-xl transition-transform duration-200 ease-out"
      >
        <div class="flex items-center justify-between border-b border-zinc-100 px-4 py-3">
          <span class="text-sm font-semibold text-zinc-900">Menu</span>
          <button
            type="button"
            data-menu-close
            aria-label="Close menu"
            class="-mr-2 inline-flex items-center justify-center rounded-lg p-2 text-zinc-500 hover:bg-zinc-100 hover:text-zinc-900"
          >
            <svg
              class="h-6 w-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 6l12 12M18 6L6 18" />
            </svg>
          </button>
        </div>
        <nav class="flex flex-1 flex-col gap-1 p-3">
          <%= if @current_user do %>
            <div class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm text-zinc-500">
              <svg
                class="h-5 w-5 shrink-0 text-zinc-400"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 12a4 4 0 100-8 4 4 0 000 8zM4.5 20a7.5 7.5 0 0115 0" />
              </svg>
              <span class="truncate">{@current_user.email}</span>
            </div>
            <.link
              href={~p"/docs"}
              class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-semibold text-indigo-700 hover:bg-indigo-50"
            >
              <svg
                class="h-5 w-5 shrink-0"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M7 3.75h6.5L18.25 8.5V20.25H7zM13 3.75V9h5M9.5 13h6M9.5 16.5h6" />
              </svg>
              My documents
            </.link>
            <.link
              href={~p"/users/settings"}
              class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-semibold text-zinc-900 hover:bg-zinc-100"
            >
              <svg
                class="h-5 w-5 shrink-0 text-zinc-500"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 15a3 3 0 100-6 3 3 0 000 6z" />
                <path d="M19.5 12.6a7.6 7.6 0 000-1.2l1.7-1.3-1.7-3-2 .8a7.5 7.5 0 00-1-.6l-.3-2.1h-3.4l-.3 2.1a7.5 7.5 0 00-1 .6l-2-.8-1.7 3 1.7 1.3a7.6 7.6 0 000 1.2l-1.7 1.3 1.7 3 2-.8c.3.2.7.4 1 .6l.3 2.1h3.4l.3-2.1c.3-.2.7-.4 1-.6l2 .8 1.7-3z" />
              </svg>
              Settings
            </.link>
            <.link
              href={~p"/users/log_out"}
              method="delete"
              class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-semibold text-zinc-900 hover:bg-zinc-100"
            >
              <svg
                class="h-5 w-5 shrink-0 text-zinc-500"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M15 12H4.5m0 0l3.5-3.5M4.5 12l3.5 3.5M14 4.5h4.25A1.75 1.75 0 0120 6.25v11.5A1.75 1.75 0 0118.25 19.5H14" />
              </svg>
              Log out
            </.link>
          <% else %>
            <.link
              href={~p"/users/register"}
              class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-semibold text-zinc-900 hover:bg-zinc-100"
            >
              <svg
                class="h-5 w-5 shrink-0 text-zinc-500"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M10 12a4 4 0 100-8 4 4 0 000 8zM3.5 20a6.5 6.5 0 0113 0M18 7v5M20.5 9.5h-5" />
              </svg>
              Register
            </.link>
            <.link
              href={~p"/users/log_in"}
              class="flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-semibold text-zinc-900 hover:bg-zinc-100"
            >
              <svg
                class="h-5 w-5 shrink-0 text-zinc-500"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M14 12H3.5m0 0L7 8.5M3.5 12L7 15.5M10 4.5h8.25A1.75 1.75 0 0120 6.25v11.5A1.75 1.75 0 0118.25 19.5H10" />
              </svg>
              Log in
            </.link>
          <% end %>
        </nav>
      </div>
    </div>
    {@inner_content}
    <footer class="border-t border-zinc-100 bg-white">
      <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-zinc-500">
        <div class="flex items-center gap-3">
          <span class="text-zinc-400">Share</span>
          <a
            href="https://twitter.com/intent/tweet?url=https%3A%2F%2Fdocshare.gatetroy.com%2F&text=DocShare%20%E2%80%94%20collaborative%20HTML%20document%20review"
            target="_blank"
            rel="noopener"
            title="Share on X"
            aria-label="Share on X"
            class="text-zinc-400 hover:text-indigo-600"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644Z" />
            </svg>
          </a>
          <a
            href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fdocshare.gatetroy.com%2F"
            target="_blank"
            rel="noopener"
            title="Share on Facebook"
            aria-label="Share on Facebook"
            class="text-zinc-400 hover:text-indigo-600"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.025 4.388 11.02 10.125 11.927v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796v8.437C19.612 23.094 24 18.099 24 12.073Z" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/sharing/share-offsite/?url=https%3A%2F%2Fdocshare.gatetroy.com%2F"
            target="_blank"
            rel="noopener"
            title="Share on LinkedIn"
            aria-label="Share on LinkedIn"
            class="text-zinc-400 hover:text-indigo-600"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z" />
            </svg>
          </a>
        </div>

        <div class="text-zinc-400">
          v{to_string(Application.spec(:docshare, :vsn))}
        </div>

        <div>
          Made by
          <a
            href="https://gatetroy.com"
            target="_blank"
            rel="noopener"
            title="DocShare — built by gatetroy.com"
            class="font-semibold text-indigo-700 hover:text-indigo-500 hover:underline"
          >
            gatetroy.com
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
